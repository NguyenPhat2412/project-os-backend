[Unit]
Description=ProjectOS PostgreSQL and MinIO backup
After=docker.service
Requires=docker.service
OnFailure=project-os-backup-failure-alert.service

[Service]
Type=oneshot
WorkingDirectory=/opt/project-os
EnvironmentFile=/etc/project-os/backup.env
ExecStart=/opt/project-os/deploy/backup/backup-project-os.sh
