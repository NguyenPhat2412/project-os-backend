{
  "info": {
    "name": "ProjectOS Backend",
    "description": "Run requests from top to bottom against the local Spring Boot backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8081" },
    { "key": "adminEmail", "value": "admin@projectos.local" },
    { "key": "adminPassword", "value": "" },
    { "key": "userEmail", "value": "" },
    { "key": "userPassword", "value": "User123!" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "projectId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/actuator/health" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Backend is healthy', () => pm.response.to.have.status(200));"] } }]
    },
    {
      "name": "2. Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Admin login succeeds', () => pm.response.to.have.status(200));",
        "if (pm.response.code === 200) pm.collectionVariables.set('adminToken', pm.response.json().accessToken);"
      ] } }]
    },
    {
      "name": "3. Register User",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["pm.collectionVariables.set('userEmail', `user.${Date.now()}@example.com`);"] } },
        { "listen": "test", "script": { "exec": [
          "pm.test('User is created', () => pm.response.to.have.status(201));",
          "pm.test('Registration cannot create admin', () => pm.expect(pm.response.json().user.role).to.eql('USER'));",
          "if (pm.response.code === 201) pm.collectionVariables.set('userToken', pm.response.json().accessToken);"
        ] } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"displayName\": \"Postman User\"\n}" },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "4. User Cannot Create Project",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Forbidden Project\"\n}" },
        "url": "{{baseUrl}}/api/projects"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('User receives 403', () => pm.response.to.have.status(403));"] } }]
    },
    {
      "name": "5. Admin Creates Project",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Project\",\n  \"description\": \"Stored in PostgreSQL\",\n  \"status\": \"ACTIVE\"\n}" },
        "url": "{{baseUrl}}/api/projects"
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Project is created', () => pm.response.to.have.status(201));",
        "if (pm.response.code === 201) pm.collectionVariables.set('projectId', pm.response.json().id);"
      ] } }]
    },
    {
      "name": "6. User Reads Project",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/projects/{{projectId}}"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Signed-in user can read', () => pm.response.to.have.status(200));"] } }]
    },
    {
      "name": "7. Admin Updates Project",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"COMPLETED\"\n}" },
        "url": "{{baseUrl}}/api/projects/{{projectId}}"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Project is completed', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('COMPLETED'); });"] } }]
    },
    {
      "name": "8. List Projects",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/projects?page=0&size=20"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Projects are paginated', () => { pm.response.to.have.status(200); pm.expect(pm.response.json()).to.have.property('content'); });"] } }]
    },
    {
      "name": "9. Admin Deletes Project",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/projects/{{projectId}}"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Project is deleted', () => pm.response.to.have.status(204));"] } }]
    }
  ]
}
